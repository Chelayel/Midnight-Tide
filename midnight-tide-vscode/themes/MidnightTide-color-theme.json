  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#71717A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment keywords (TODO, FIXME, etc.)",
      "scope": [
        "keyword.codetag.notation",
        "comment.notation",
        "comment todo",
        "comment fixme"
      ],
      "settings": {
        "foreground": "#FACC15",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other"
      ],
      "settings": {
        "foreground": "#E4E4E7"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "constant.other",
        "constant.other.symbol",
        "constant.other.key"
      ],
      "settings": {
        "foreground": "#C084FC"
      }
    },
    {
      "name": "Language constants (true, false, null, undefined)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#C084FC"
      }
    },
    {
      "name": "this / self",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super",
        "variable.language.special.self"
      ],
      "settings": {
        "foreground": "#C084FC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
